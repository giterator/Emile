# Copy this file to .env and fill in your key(s).
# Only ANTHROPIC_API_KEY is required to run the agent.

# --- REQUIRED ---
# Anthropic — Claude Sonnet 4.6 (agent brain)
# Get key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# --- OPTIONAL (alternative LLM backends, see LLM_PROVIDER in agent.py) ---
# Groq — 14,400 req/day free  https://console.groq.com
GROQ_API_KEY=

# Gemini — 1500 req/day free  https://aistudio.google.com
GOOGLE_API_KEY=

# Cerebras — 60k TPM free  https://console.cerebras.ai
CEREBRAS_API_KEY=

# DeepSeek — paid, high limits  https://platform.deepseek.com
DEEPSEEK_API_KEY=
